@page
@model OpenGate.UI.Pages.Admin.Scopes.CreateModel
@{
    ViewData["Title"] = "Novo scope";
}

<section class="space-y-6">
    <div class="og-page-header">
        <div>
            <h1 class="text-3xl font-semibold tracking-tight">Novo scope</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400">Registra um novo scope OpenIddict e seus resources.</p>
        </div>
        <a href="/Admin/Scopes" class="og-btn-ghost">Voltar</a>
    </div>

    <form method="post" class="space-y-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-gray-900">
        <div asp-validation-summary="ModelOnly" class="rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-950/40 dark:text-red-400 [&.validation-summary-valid]:hidden"></div>

        <div class="grid gap-4 lg:grid-cols-2">
            <div>
                <label asp-for="Input.Name" class="og-label">Nome do scope</label>
                <input asp-for="Input.Name" class="og-input font-mono" placeholder="openid, profile, api, myservice" />
                <span asp-validation-for="Input.Name" class="og-field-error"></span>
                <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">Identificador único. Não pode ser alterado após criação.</p>
            </div>
            <div>
                <label asp-for="Input.DisplayName" class="og-label">Nome de exibição</label>
                <input asp-for="Input.DisplayName" class="og-input" placeholder="Minha API" />
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.Description" class="og-label">Descrição</label>
                <textarea asp-for="Input.Description" rows="2" class="og-input" placeholder="Descreva o que este scope representa e quais dados acessa."></textarea>
            </div>
            <div class="lg:col-span-2">
                <label asp-for="Input.Resources" class="og-label">
                    Resources <span class="font-normal text-gray-400">(API audiences)</span>
                </label>
                <textarea asp-for="Input.Resources" rows="3" class="og-input font-mono text-xs" placeholder="my-api&#10;resource-server-1"></textarea>
                <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
                    Nome dos servidores de recursos (audiences) que recebem este scope no token. Um por linha ou separados por vírgula.
                </p>
            </div>
        </div>

        <div class="flex flex-wrap justify-end gap-3">
            <a href="/Admin/Scopes" class="og-btn-ghost">Cancelar</a>
            <button type="submit" class="og-btn-action">Criar scope</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
